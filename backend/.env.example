# Copier ce fichier en .env et adapter si besoin.

# Connexion PostgreSQL (driver psycopg v3)
DATABASE_URL=postgresql+psycopg://greenscan:greenscan@localhost:5432/greenscan

# Paramètres métier
CO2_FACTOR_KG_PER_KWH=0.052        # facteur d'émission moyen électricité FR (kgCO2/kWh)
PRICE_HP_EUR_PER_KWH=0.2516        # tarif heures pleines (€/kWh)
PRICE_HC_EUR_PER_KWH=0.2032        # tarif heures creuses (€/kWh)

# CORS - origines autorisées (frontend Vite)
FRONTEND_ORIGIN=http://localhost:5173

# Dossier des artefacts ML
ML_ARTIFACTS_DIR=ml/artifacts
